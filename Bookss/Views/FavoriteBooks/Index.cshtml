@model IEnumerable<Bookss.Models.MyFavoriteBook>

@{
    ViewData["Title"] = "Index";
}

<h1 class="text-center text-white text-2xl">Favorite Books List</h1>
<div class="grid grid-cols-4 grid-rows-3">
    @if (Model.Count() == 0)
    {
        <p class="text-center text-white text-2xl">You have no favorite books.</p>
    }
    else
    {
        @foreach (var item in Model)
        {
            <div class="flex flex-col items-center border border-x-blue-950 rounded-2xl bg-blue-950 w-52">
                <img src="@item.Book.ImageUrl" alt="@item.Book.Title" class="w-full h-36 rounded-lg" />
                <div class="">
                    <p class="text-white text-sm text-8">@item.Book.Title</p>
                    <p class="text-white text-sm text-8">@item.Book.Author.Name</p>
                    <p class="text-white text-sm text-8">@item.Book.Genre.Name</p>
                    <a asp-controller="Books" asp-action="Details" asp-route-id="@item.BookId"
                        class="btn btn-primary hover:bg-blue-500 hover:text-white border border-x-blue-950">Details</a>
                </div>
            </div>
        }
    }
</div>
