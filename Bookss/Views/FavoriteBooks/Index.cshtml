@model IEnumerable<Bookss.Models.MyFavoriteBook>

@{
    ViewData["Title"] = "My Favorites";
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center mb-12">
        <div>
            <h1 class="text-4xl font-bold text-white tracking-tight">Your <span class="text-rose-400">Favorites</span></h1>
            <p class="mt-2 text-gray-400">The collection of stories that moved you.</p>
        </div>
        <a asp-controller="Books" asp-action="Index" class="text-sm font-semibold text-rose-400 hover:text-rose-300 flex items-center transition-all group">
            <svg class="mr-2 w-4 h-4 transform group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
            Explore More Books
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="flex flex-col items-center justify-center py-24 bg-slate-900/30 rounded-3xl border border-dashed border-white/10">
            <div class="p-6 bg-rose-500/10 rounded-full mb-6">
                <svg class="w-12 h-12 text-rose-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                </svg>
            </div>
            <h2 class="text-2xl font-bold text-white">Your list is empty</h2>
            <p class="mt-2 text-gray-500 text-center max-w-sm">Start exploring our library and save the books you love most.</p>
            <a asp-controller="Books" asp-action="Index" class="mt-8 px-6 py-3 bg-rose-500 text-white rounded-xl font-bold hover:bg-rose-600 transition-all shadow-lg shadow-rose-500/20">
                Discover Books
            </a>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
            @foreach (var item in Model)
            {
                <article class="group relative bg-slate-900/40 backdrop-blur-md border border-white/5 rounded-2xl overflow-hidden hover:border-rose-500/50 transition-all duration-500 hover:shadow-2xl hover:shadow-rose-500/10 hover:-translate-y-2">
                    <div class="aspect-[2/3] w-full overflow-hidden bg-slate-800">
                        @if (!string.IsNullOrEmpty(item.Book?.ImageUrl))
                        {
                            <img src="@item.Book.ImageUrl" 
                                 alt="@item.Book.Title" 
                                 class="h-full w-full object-cover group-hover:scale-110 transition-transform duration-700" 
                                 loading="lazy" />
                        }
                        else
                        {
                            <div class="flex items-center justify-center h-full bg-gradient-to-br from-slate-800 to-slate-900">
                                <span class="text-slate-600 text-3xl font-bold">@item.Book?.Title?[0]</span>
                            </div>
                        }
                        
                        <!-- Remove Action (Always visible on hover or mobile) -->
                        <div class="absolute top-4 right-4 z-10">
                            <form asp-action="RemoveFromFavorites" method="post" class="inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="bookId" value="@item.BookId" />
                                <button type="submit" 
                                        class="p-2.5 bg-slate-900/80 backdrop-blur-md text-white rounded-full hover:bg-rose-500 transition-all shadow-xl border border-white/10 group/btn"
                                        aria-label="Remove from favorites">
                                    <svg class="w-5 h-5 group-hover/btn:scale-110 transition-transform" 
                                         fill="currentColor" 
                                         viewBox="0 0 24 24">
                                        <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z" />
                                    </svg>
                                </button>
                            </form>
                        </div>

                        <!-- Hover Action Overlay -->
                        <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-slate-900/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col justify-end p-6">
                            <a asp-controller="Books" 
                               asp-action="Details" 
                               asp-route-id="@item.BookId" 
                               class="w-full bg-white text-slate-950 text-center py-2.5 rounded-xl font-bold text-sm transform transition-transform translate-y-4 group-hover:translate-y-0 hover:bg-slate-100 shadow-xl">
                                View Details
                            </a>
                        </div>
                    </div>
                    
                    <div class="p-5">
                        <div class="flex flex-col space-y-2">
                            <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-rose-500/10 text-rose-400 border border-rose-500/20 w-fit">
                                @item.Book?.Genre?.Name
                            </span>
                            <h3 class="text-lg font-bold text-white group-hover:text-rose-400 transition-colors line-clamp-1">@item.Book?.Title</h3>
                            <p class="text-sm text-gray-400 italic">by @(item.Book?.Author?.Name ?? "Unknown Author")</p>
                        </div>
                    </div>
                </article>
            }
        </div>
    }
</div>
