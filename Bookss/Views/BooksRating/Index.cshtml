@model IEnumerable<Bookss.Models.BooksRating>

@{
    ViewData["Title"] = "Index";
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="flex justify-between items-center mb-12">
        <div>
            <h1 class="text-4xl font-bold text-white tracking-tight">Your <span class="text-indigo-400">Reviews</span>
            </h1>
            <p class="mt-2 text-gray-400">Manage your ratings and feedback for the library.</p>
        </div>
        @if (User.Identity.IsAuthenticated)
        {
            <a asp-action="Create"
                class="px-6 py-2.5 bg-indigo-500 hover:bg-indigo-400 text-slate-950 font-bold rounded-xl transition-all shadow-lg shadow-indigo-500/20 no-underline!">
                Add New Review
            </a>
        }
    </div>

    @if (!Model.Any())
    {
        <div
            class="flex flex-col items-center justify-center py-24 bg-slate-900/30 rounded-3xl border border-dashed border-white/10">
            <p class="text-gray-500 text-lg">You haven't written any reviews yet.</p>
            <a asp-controller="Books" asp-action="Index"
                class="mt-6 text-indigo-400 hover:text-indigo-300 font-medium">Browse books to rate them</a>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            @foreach (var item in Model)
            {
                <div
                    class="bg-slate-900/40 backdrop-blur-md border border-white/5 rounded-2xl p-6 hover:border-indigo-500/30 transition-all group shadow-xl">
                    <div class="flex justify-between items-start mb-4">
                        <h3 class="text-lg font-bold text-white group-hover:text-indigo-400 transition-colors">@item.Book?.Title
                        </h3>
                        <div class="flex items-center bg-indigo-500/10 px-2 py-1 rounded-lg border border-indigo-500/20">
                            <svg class="w-4 h-4 text-indigo-400 mr-1" fill="currentColor" viewBox="0 0 20 20">
                                <path
                                    d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                            </svg>
                            <span class="text-indigo-400 font-bold">@item.Rating</span>
                        </div>
                    </div>

                    <p class="text-gray-400 text-sm leading-relaxed line-clamp-3 mb-6">@item.Text</p>

                    <div class="flex items-center gap-4 pt-4 border-t border-white/5">
                        <a asp-action="Edit" asp-route-id="@item.Id"
                            class="text-sm font-bold text-gray-500 hover:text-white transition-colors">Edit</a>
                        <a asp-action="Details" asp-route-id="@item.Id"
                            class="text-sm font-bold text-gray-500 hover:text-white transition-colors">Details</a>
                        <a asp-action="Delete" asp-route-id="@item.Id"
                            class="text-sm font-bold text-red-500 hover:text-red-400 transition-colors">Delete</a>
                    </div>
                </div>
            }
        </div>
    }
</div>
