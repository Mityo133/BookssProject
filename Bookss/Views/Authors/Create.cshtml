@model Bookss.Models.Author

@{
    ViewData["Title"] = "Create";
}

<div class="flex items-center justify-center min-h-screen p-4 py-24">
    <div
        class="bg-slate-900/40 backdrop-blur-md border border-white/5 rounded-3xl shadow-2xl p-8 md:p-12 w-full max-w-xl mx-auto">
        <div class="text-center mb-10">
            <h1 class="text-3xl font-bold text-white tracking-tight">Add New <span class="text-cyan-400">Author</span>
            </h1>
            <p class="mt-2 text-gray-400">Introduce a new creative mind to the collection.</p>
        </div>

        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly"
                class="text-red-400 mb-6 text-sm bg-red-400/10 p-4 rounded-xl border border-red-400/20"></div>

            <div class="space-y-6">
                <div>
                    <label asp-for="Name"
                        class="block text-sm font-bold text-gray-400 uppercase tracking-widest mb-2 ml-1">Full
                        Name</label>
                    <input asp-for="Name"
                        class="w-full bg-slate-800/50 border border-white/10 rounded-xl py-3 px-4 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-cyan-500 focus:border-transparent transition-all"
                        placeholder="e.g. Jane Austen" />
                    <span asp-validation-for="Name" class="text-red-400 text-xs mt-1 ml-1"></span>
                </div>

                <div>
                    <label asp-for="Age"
                        class="block text-sm font-bold text-gray-400 uppercase tracking-widest mb-2 ml-1">Age</label>
                    <input asp-for="Age" type="number"
                        class="w-full bg-slate-800/50 border border-white/10 rounded-xl py-3 px-4 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-cyan-500 focus:border-transparent transition-all"
                        placeholder="e.g. 42" />
                    <span asp-validation-for="Age" class="text-red-400 text-xs mt-1 ml-1"></span>
                </div>

                <div>
                    <label asp-for="ImageUrl"
                        class="block text-sm font-bold text-gray-400 uppercase tracking-widest mb-2 ml-1">Image URL</label>
                    <input asp-for="ImageUrl"
                        class="w-full bg-slate-800/50 border border-white/10 rounded-xl py-3 px-4 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-cyan-500 focus:border-transparent transition-all"
                        placeholder="e.g. https://example.com/image.jpg" />
                    <span asp-validation-for="ImageUrl" class="text-red-400 text-xs mt-1 ml-1"></span>
                </div>

                <div>
                    <label asp-for="Description"
                        class="block text-sm font-bold text-gray-400 uppercase tracking-widest mb-2 ml-1">Biography</label>
                    <textarea asp-for="Description" rows="4"
                        class="w-full bg-slate-800/50 border border-white/10 rounded-xl py-3 px-4 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-cyan-500 focus:border-transparent transition-all"
                        placeholder="Tell us about the author's life and work..."></textarea>
                    <span asp-validation-for="Description" class="text-red-400 text-xs mt-1 ml-1"></span>
                </div>

                <div class="pt-6 flex flex-col sm:flex-row gap-4">
                    <button type="submit"
                        class="flex-1 px-8 py-4 bg-cyan-500 hover:bg-cyan-400 text-slate-950 font-bold rounded-2xl transition-all shadow-lg shadow-cyan-500/20 transform hover:-translate-y-1">
                        Create Author
                    </button>
                    <a asp-action="Index"
                        class="px-8 py-4 bg-slate-800 hover:bg-slate-700 text-white font-bold rounded-2xl transition-all text-center no-underline!">
                        Cancel
                    </a>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
