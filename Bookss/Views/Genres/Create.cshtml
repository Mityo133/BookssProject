@model Bookss.Models.Genre

@{
    ViewData["Title"] = "Add New Genre";
}

<div class="max-w-4xl mx-auto px-4 py-12">
    <div class="mb-12">
        <a asp-action="Index"
            class="text-gray-400 hover:text-indigo-400 text-sm font-medium transition-colors flex items-center mb-6">
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
            </svg>
            Back to Genres
        </a>
        <h1 class="text-4xl font-bold text-white tracking-tight">Add <span class="text-indigo-400">New Genre</span></h1>
        <p class="mt-2 text-gray-500">Create a new category for your book library.</p>
    </div>

    <div class="bg-slate-900/50 backdrop-blur-xl border border-white/5 rounded-3xl p-8 shadow-2xl">
        <form asp-action="Create" class="space-y-8">
            <div asp-validation-summary="ModelOnly"
                class="p-4 bg-red-500/10 border border-red-500/20 rounded-xl text-red-400 text-sm"></div>

            <div class="space-y-6">
                <!-- Name Field -->
                <div>
                    <label asp-for="Name" class="block text-sm font-semibold text-gray-300 mb-2 ms-1">Genre Name</label>
                    <div class="relative">
                        <input asp-for="Name"
                            class="block w-full px-5 py-4 bg-slate-800/50 border border-slate-700 rounded-2xl text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500 transition-all"
                            placeholder="e.g. Science Fiction, Mystery, Biography" />
                    </div>
                    <span asp-validation-for="Name" class="mt-2 text-xs text-red-400 block ms-1"></span>
                </div>

                <!-- Description Field -->
                <div>
                    <label asp-for="Description"
                        class="block text-sm font-semibold text-gray-300 mb-2 ms-1">Description</label>
                    <div class="relative">
                        <textarea asp-for="Description" rows="4"
                            class="block w-full px-5 py-4 bg-slate-800/50 border border-slate-700 rounded-2xl text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500 transition-all resize-none"
                            placeholder="Describe what kind of books belong in this genre..."></textarea>
                    </div>
                    <span asp-validation-for="Description" class="mt-2 text-xs text-red-400 block ms-1"></span>
                </div>
            </div>

            <div class="pt-4 flex items-center gap-4">
                <button type="submit"
                    class="flex-1 px-8 py-4 bg-indigo-500 hover:bg-indigo-400 text-black font-bold rounded-2xl transition-all shadow-lg shadow-indigo-500/20 active:scale-95">
                    Create Genre
                </button>
                <a asp-action="Index"
                    class="px-8 py-4 bg-slate-800 hover:bg-slate-700 text-gray-300 font-bold rounded-2xl transition-all border border-slate-700">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
