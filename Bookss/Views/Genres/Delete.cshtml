@model Bookss.Models.Genre

@{
    ViewData["Title"] = "Delete Genre";
}

<div class="max-w-3xl mx-auto px-4 py-16">
    <div class="bg-slate-900/50 backdrop-blur-xl border border-red-500/20 rounded-3xl p-8 md:p-12 shadow-2xl text-center">
        <div class="mb-12">
        <a asp-action="Index" class="text-gray-400 hover:text-indigo-400 text-sm font-medium transition-colors flex items-center mb-6">
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
            </svg>
            Back to Genres
        </a>
        <h1 class="text-4xl font-bold text-white tracking-tight">Delete <span class="text-indigo-400">Genre</span></h1>
        <p class="mt-2 text-gray-500 italic">Are you sure you want to delete "@Model.Name"? This action cannot be undone.</p>
    </div>

    <div class="bg-slate-900/50 backdrop-blur-xl border border-red-500/10 rounded-3xl p-8 shadow-2xl">
        <div class="mb-8">
            <h2 class="text-2xl font-bold text-white">@Model.Name</h2>
            @if (!string.IsNullOrEmpty(Model.Description))
            {
                <p class="text-gray-400 mt-4 leading-relaxed">@Model.Description</p>
            }
        </div>

        @if (Model.Books?.Any() == true)
        {
            <div class="mb-8 p-4 bg-red-500/10 border border-red-500/20 rounded-2xl">
                <p class="text-red-400 text-sm font-medium flex items-center">
                    <svg class="w-5 h-5 mr-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
                    </svg>
                    Warning: There are @Model.Books.Count() books associated with this genre. Deleting this genre might cause issues or require updating those books.
                </p>
            </div>
        }
        <form asp-action="Delete" class="flex flex-col sm:flex-row gap-4">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="flex-1 px-8 py-4 bg-red-500 hover:bg-red-600 text-white font-bold rounded-2xl transition-all shadow-lg shadow-red-500/20 active:scale-95">
                Confirm Delete
            </button>
            <a asp-action="Index" class="flex-1 px-8 py-4 bg-slate-800 hover:bg-slate-700 text-gray-300 font-bold rounded-2xl transition-all border border-slate-700">
                Cancel
            </a>
        </form>
    </div>
</div>
