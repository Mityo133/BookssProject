@model Bookss.Models.Genre

@{
    ViewData["Title"] = $"{Model.Name} - Genre Details";
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Header Section -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-12 gap-6">
        <div>
            <nav class="flex mb-4" aria-label="Breadcrumb">
                <ol class="inline-flex items-center space-x-1 md:space-x-3 text-sm font-medium">
                    <li class="inline-flex items-center">
                        <a asp-action="Index" class="text-gray-400 hover:text-indigo-400 transition-colors">Genres</a>
                    </li>
                    <li>
                        <div class="flex items-center">
                            <svg class="w-4 h-4 text-gray-600 mx-1" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"></path>
                            </svg>
                            <span class="text-indigo-400/80">@Model.Name</span>
                        </div>
                    </li>
                </ol>
            </nav>
            <h1 class="text-4xl md:text-5xl font-bold text-white tracking-tight mb-4">
                Genre: <span class="text-indigo-400">@Model.Name</span>
            </h1>
            @if (!string.IsNullOrEmpty(Model.Description))
            {
                <p class="text-gray-400 text-lg max-w-4xl leading-relaxed">@Model.Description</p>
            }
        </div>
        
        <div class="flex gap-4">
            @if (User.IsInRole("Admin"))
            {
                <a asp-action="Edit" asp-route-id="@Model.Id" class="inline-flex items-center px-4 py-2 border border-slate-700 rounded-lg text-sm font-medium text-gray-300 bg-slate-800/50 hover:bg-slate-700 transition-colors">
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                    </svg>
                    Edit Genre
                </a>
            }
            <a asp-action="Index" class="inline-flex items-center px-4 py-2 border border-slate-700 rounded-lg text-sm font-medium text-gray-300 bg-slate-800/50 hover:bg-slate-700 transition-colors">
                Back to All Genres
            </a>
        </div>
    </div>

    <!-- Books Section -->
    <div class="mt-16">
        <div class="flex items-center justify-between mb-8">
            <h2 class="text-2xl font-bold text-white flex items-center gap-3">
                Books in this Genre
                <span class="px-3 py-1 text-xs font-medium bg-indigo-500/10 text-indigo-400 rounded-full border border-indigo-500/20">
                    @(Model.Books?.Count() ?? 0) @(Model.Books?.Count() == 1 ? "Book" : "Books")
                </span>
            </h2>
        </div>

        @if (Model.Books != null && Model.Books.Any())
        {
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 xl:grid-cols-6 gap-8">
                @foreach (var book in Model.Books)
                {
                    <div class="group relative bg-slate-900/40 backdrop-blur-md border border-white/5 rounded-2xl overflow-hidden hover:border-indigo-500/50 transition-all duration-500 hover:shadow-2xl hover:shadow-indigo-500/10 hover:-translate-y-2">
                        <div class="aspect-2/3 w-full overflow-hidden bg-slate-800 relative">
                            @if (!string.IsNullOrEmpty(book.ImageUrl))
                            {
                                <img src="@book.ImageUrl" 
                                     alt="@book.Title" 
                                     class="h-full w-full object-cover group-hover:scale-110 transition-transform duration-700" 
                                     loading="lazy" />
                            }
                            else
                            {
                                <div class="flex items-center justify-center h-full bg-linear-to-br from-slate-800 to-slate-900">
                                    <span class="text-slate-600 text-3xl font-bold">@book.Title?[0]</span>
                                </div>
                            }
                            
                            <!-- Entire card link -->
                            <a asp-controller="Books" asp-action="Details" asp-route-id="@book.Id" class="absolute inset-0 z-10">
                                <span class="sr-only">View Details for @book.Title</span>
                            </a>

                            <!-- Hover Action Overlay (Button style) -->
                            <div class="absolute inset-0 bg-linear-to-t from-slate-950 via-slate-900/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col justify-end p-4 z-20 pointer-events-none">
                                <div class="w-full bg-white text-slate-950 text-center py-2.5 rounded-xl font-bold text-xs transform transition-transform translate-y-4 group-hover:translate-y-0 shadow-xl">
                                    View Details
                                </div>
                            </div>
                        </div>
                        
                        <div class="p-4">
                            <h3 class="text-sm font-bold text-white group-hover:text-indigo-400 transition-colors truncate">@book.Title</h3>
                            @if (book.Author != null)
                            {
                                <p class="text-xs text-gray-400 mt-1 truncate italic">by @book.Author.Name</p>
                            }
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="flex flex-col items-center justify-center py-24 border-2 border-dashed border-white/5 rounded-3xl bg-slate-900/50 backdrop-blur-sm">
                <div class="p-5 bg-indigo-500/10 rounded-2xl mb-6">
                    <svg class="w-10 h-10 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
                    </svg>
                </div>
                <h3 class="text-xl font-bold text-white">No books yet</h3>
                <p class="text-gray-400 mt-2 text-center max-w-sm">We are working on adding titles to the <span class="text-indigo-400/80">@Model.Name</span> collection. Stay tuned!</p>
            </div>
        }
    </div>
</div>
