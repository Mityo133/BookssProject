@model Bookss.Models.Book

@{
    ViewData["Title"] = "Edit";
}

<div class="flex items-center justify-center min-h-screen p-4 py-24">
    <div
        class="bg-slate-900/40 backdrop-blur-md border border-white/5 rounded-3xl shadow-2xl p-8 md:p-12 w-full max-w-2xl mx-auto">
        <div class="text-center mb-10">
            <h1 class="text-3xl font-bold text-white tracking-tight">Edit <span class="text-indigo-400">Book</span></h1>
            <p class="mt-2 text-gray-400">Update the details for "@Model.Title".</p>
        </div>

        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly"
                class="text-red-400 mb-6 text-sm bg-red-400/10 p-4 rounded-xl border border-red-400/20"></div>
            <input type="hidden" asp-for="Id" />

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div class="space-y-6">
                    <div>
                        <label asp-for="Title"
                            class="block text-sm font-bold text-gray-400 uppercase tracking-widest mb-2 ml-1">Book
                            Title</label>
                        <input asp-for="Title"
                            class="w-full bg-slate-800/50 border border-white/10 rounded-xl py-3 px-4 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition-all" />
                        <span asp-validation-for="Title" class="text-red-400 text-xs mt-1 ml-1"></span>
                    </div>

                    <div>
                        <label asp-for="ImageUrl"
                            class="block text-sm font-bold text-gray-400 uppercase tracking-widest mb-2 ml-1">Cover
                            Image URL</label>
                        <input asp-for="ImageUrl"
                            class="w-full bg-slate-800/50 border border-white/10 rounded-xl py-3 px-4 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition-all" />
                        <span asp-validation-for="ImageUrl" class="text-red-400 text-xs mt-1 ml-1"></span>
                    </div>

                    <div>
                        <label asp-for="GenreId"
                            class="block text-sm font-bold text-gray-400 uppercase tracking-widest mb-2 ml-1">Genre</label>
                        <select asp-for="GenreId"
                            class="w-full bg-slate-800/50 border border-white/10 rounded-xl py-3 px-4 text-white focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition-all appearance-none cursor-pointer"
                            asp-items="ViewBag.GenreId"></select>
                        <span asp-validation-for="GenreId" class="text-red-400 text-xs mt-1 ml-1"></span>
                    </div>

                    <div>
                        <label asp-for="AuthorId"
                            class="block text-sm font-bold text-gray-400 uppercase tracking-widest mb-2 ml-1">Author</label>
                        <select asp-for="AuthorId"
                            class="w-full bg-slate-800/50 border border-white/10 rounded-xl py-3 px-4 text-white focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition-all appearance-none cursor-pointer"
                            asp-items="ViewBag.AuthorId"></select>
                        <span asp-validation-for="AuthorId" class="text-red-400 text-xs mt-1 ml-1"></span>
                    </div>
                </div>

                <div class="space-y-6">
                    <div>
                        <label asp-for="Description"
                            class="block text-sm font-bold text-gray-400 uppercase tracking-widest mb-2 ml-1">Description</label>
                        <textarea asp-for="Description" rows="10"
                            class="w-full bg-slate-800/50 border border-white/10 rounded-xl py-3 px-4 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition-all resize-none"></textarea>
                        <span asp-validation-for="Description" class="text-red-400 text-xs mt-1 ml-1"></span>
                    </div>
                </div>
            </div>

            <div class="pt-10 flex flex-col sm:flex-row gap-4">
                <button type="submit"
                    class="flex-1 px-8 py-4 bg-indigo-500 hover:bg-indigo-400 text-slate-950 font-bold rounded-2xl transition-all shadow-lg shadow-indigo-500/20 transform hover:-translate-y-1">
                    Save Changes
                </button>
                <a asp-action="Index"
                    class="px-8 py-4 bg-slate-800 hover:bg-slate-700 text-white font-bold rounded-2xl transition-all text-center no-underline!">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
