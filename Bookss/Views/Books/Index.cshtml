@model IEnumerable<Bookss.Models.Book>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<div class="grid grid-cols-4 grid-rows-3">
    @foreach (var item in Model)
    {
        <div class="flex flex-col items-center border border-x-blue-950 rounded-2xl bg-blue-950 w-52">
            <img src="@item.ImageUrl" alt="@item.Title" class="w-full h-36 rounded-lg" />
            <div class="">
                <h5 class="text-white text-sm">@item.Title</h5>
                <h5  class="text-white text-sm">@item.Author.Name</h5>
                <h5 class="text-white text-sm">@item.Genre.Name</h5>
                <a asp-action="Details" asp-route-id="@item.Id"
                    class="btn btn-primary hover:bg-blue-500 hover:text-white border border-x-blue-950">Details</a>
            </div>
        </div>
    }
</div>
