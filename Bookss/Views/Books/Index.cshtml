@model IEnumerable<Bookss.Models.Book>

@{
    ViewData["Title"] = "Books";
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-12 gap-6">
        <div>
            <h1 class="text-4xl font-bold text-white tracking-tight">Our <span class="text-indigo-400">Library</span>
            </h1>
            <p class="mt-2 text-gray-400">Explore our collection of stories and knowledge.</p>
        </div>

        <div class="flex flex-1 max-w-md w-full">
            <form asp-action="Index" method="get" class="relative w-full group">
                <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" 
                       placeholder="Search by title, author or genre..." 
                       class="w-full bg-slate-900/50 border border-white/10 rounded-xl py-2.5 pl-4 pr-12 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition-all group-hover:border-white/20" />
                <button type="submit" class="absolute right-2 top-1/2 -translate-y-1/2 p-1.5 text-gray-400 hover:text-indigo-400 transition-colors">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                    </svg>
                </button>
            </form>
        </div>

        @if (User.IsInRole("Admin"))
        {
                <a asp-action="Create"
                    class="inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-slate-950 bg-indigo-400 hover:bg-indigo-300 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-all">
                    Add New Book
                </a>
        }
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
        @foreach (var item in Model)
        {
                <div
                    class="group relative bg-slate-900/40 backdrop-blur-md border border-white/5 rounded-2xl overflow-hidden hover:border-indigo-500/50 transition-all duration-500 hover:shadow-2xl hover:shadow-indigo-500/10 hover:-translate-y-2">
                    <div class="aspect-2/3 w-full overflow-hidden bg-slate-800">
                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                    {
                                <img src="@item.ImageUrl" alt="@item.Title"
                                    class="h-full w-full object-cover group-hover:scale-110 transition-transform duration-700" />
                    }
                    else
                    {
                                <div class="flex items-center justify-center h-full bg-linear-to-br from-slate-800 to-slate-900">
                                    <span class="text-slate-600 text-3xl font-bold">@item.Title[0]</span>
                                </div>
                    }

                        <!-- Hover Action Overlay -->
                        <div
                            class="absolute inset-0 bg-linear-to-t from-slate-950 via-slate-900/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col justify-end p-6">
                            <a asp-action="Details" asp-route-id="@item.Id"
                                class="w-full bg-white text-slate-950 text-center py-2.5 rounded-xl font-bold text-sm transform transition-transform translate-y-4 group-hover:translate-y-0 no-underline! hover:bg-slate-100 shadow-xl">
                                View Details
                            </a>
                        </div>
                    </div>

                    <div class="p-5">
                        <div class="flex flex-col space-y-2">
                            <span
                                class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-indigo-500/10 text-indigo-400 border border-indigo-500/20 w-fit">
                            @item.Genre.Name
                            </span>
                            <h3 class="text-lg font-bold text-white group-hover:text-indigo-400 transition-colors line-clamp-1">
                            @item.Title</h3>
                            <p class="text-sm text-gray-400 italic">by @(item.Author?.Name ?? "Unknown Author")</p>
                        </div>

                    @if (User.IsInRole("Admin"))
                    {
                                <div class="mt-4 pt-4 border-t border-white/5 flex items-center space-x-3">
                                    <a asp-action="Edit" asp-route-id="@item.Id"
                                        class="text-xs font-medium text-gray-500 hover:text-indigo-400 transition-colors">Edit</a>
                                    <span class="text-gray-800">|</span>
                                    <a asp-action="Delete" asp-route-id="@item.Id"
                                        class="text-xs font-medium text-red-400/70 hover:text-red-400 transition-colors">Delete</a>
                                    <span class="text-gray-800">|</span>
                                    <a asp-action="Details" asp-route-id="@item.Id"
                                        class="text-xs font-medium text-indigo-400/70 hover:text-indigo-400 transition-colors">Details</a>
                                    <a asp-action="AddToFavorites" asp-controller="FavoriteBooks" asp-route-id="@item.Id"
                                        class="text-xs font-medium text-indigo-400/70 hover:text-indigo-400 transition-colors">Add to
                                        Favorites</a>
                                </div>
                    }
                    else
                    {
                                 <div class="mt-4 pt-4 border-t border-white/5 flex items-center space-x-3">

                                    <a asp-action="Details" asp-route-id="@item.Id"
                                        class="text-xs font-medium text-indigo-400/70 hover:text-indigo-400 transition-colors">Details</a>
                                    <a asp-action="AddToFavorites" asp-controller="FavoriteBooks" asp-route-id="@item.Id"
                                        class="text-xs font-medium text-indigo-400/70 hover:text-indigo-400 transition-colors">Add to
                                        Favorites</a>
                                </div>
                    }
                    </div>
                </div>
        }
    </div>
</div>
