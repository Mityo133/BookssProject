@using System.Security.Claims
@model Bookss.Models.Book

@{
    ViewData["Title"] = "Book Details";
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="flex flex-col lg:flex-row gap-12">
        <!-- Book Cover Section -->
        <div class="lg:w-2/5 flex justify-center">
            <div class="relative">
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <img src="@Model.ImageUrl" 
                         alt="@Model.Title" 
                         class="w-full max-w-md h-auto rounded-2xl shadow-2xl border border-white/10 object-cover aspect-2/3" 
                         onerror="this.src='https://placehold.co/300x450?text=No+Image'" />
                }
                else
                {
                    <div class="w-full max-w-md h-auto rounded-2xl shadow-2xl border border-white/10 aspect-2/3 bg-linear-to-br from-slate-800 to-slate-900 flex items-center justify-center">
                        <span class="text-6xl font-bold text-slate-600">@Model.Title?[0]</span>
                    </div>
                }
                
                <!-- Badge overlay -->
                <div class="absolute top-4 left-4">
                    <span class="px-3 py-1 bg-rose-500/90 text-white text-xs font-bold rounded-full backdrop-blur-sm">
                        @Model.Genre?.Name
                    </span>
                </div>
            </div>
        </div>

        <!-- Book Information Section -->
        <div class="lg:w-3/5">
            <div class="mb-6">
                <h1 class="text-4xl md:text-5xl font-bold text-white mb-2">@Model.Title</h1>
                <p class="text-xl text-gray-300 mb-1">by <span class="font-semibold text-rose-400">@Model.Author?.Name</span></p>
                <div class="flex items-center mt-4">
                    <div class="flex text-amber-400 mr-2">
                        @{
                            var ratings = Model.BooksRating ?? new List<BooksRating>();
                            var avgRating = ratings.Any() ? ratings.Average(r => r.Rating) : 0;
                            var reviewCount = ratings.Count();
                        }
                        @for (int i = 1; i <= 5; i++)
                        {
                            <svg class="w-5 h-5 @(i <= Math.Round(avgRating) ? "fill-current" : "text-gray-600 fill-none stroke-current")" viewBox="0 0 24 24">
                                <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>
                            </svg>
                        }
                    </div>
                    <span class="text-gray-400 text-sm">(@reviewCount reviews)</span>
                </div>
            </div>

            <!-- Description -->
            <div class="mb-8">
                <h2 class="text-2xl font-bold text-white mb-4">Description</h2>
                <p class="text-gray-300 leading-relaxed">
                    @Model.Description
                </p>
            </div>

            <!-- ... Metadata grid (kept for brevity) ... -->

            <!-- Action Buttons -->
            <div class="flex flex-wrap gap-4 mb-8">
                @if (User.Identity.IsAuthenticated)
                {
                    <a asp-controller="BooksRating" asp-action="Create" asp-route-bookId="@Model.Id" 
                       class="px-6 py-3 bg-indigo-500 hover:bg-indigo-600 text-white font-bold rounded-xl transition-all duration-300 flex items-center shadow-lg shadow-indigo-500/20 hover:shadow-indigo-500/40">
                        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.921-.755 1.688-1.54 1.118l-3.976-2.888a1 1 0 00-1.175 0l-3.976 2.888c-.784.57-1.838-.197-1.539-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
                        </svg>
                        Rate & Comment
                    </a>

                    <!-- Existing Favorite buttons -->
                    <form asp-controller="FavoriteBooks" asp-action="AddToFavorites" method="post">
                        <input type="hidden" name="bookId" value="@Model.Id" />
                        @Html.AntiForgeryToken()
                        <button type="submit" 
                                class="px-6 py-3 bg-rose-500 hover:bg-rose-600 text-white font-bold rounded-xl transition-all duration-300 flex items-center shadow-lg shadow-rose-500/20 hover:shadow-rose-500/40">
                            <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
                            </svg>
                            Add to Favorites
                        </button>
                    </form>
                }
                else
                {
                    <div class="w-full p-4 bg-amber-500/10 border border-amber-500/20 rounded-xl">
                        <p class="text-amber-300 flex items-center">
                            <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/>
                            </svg>
                            Please <a asp-area="Identity" asp-page="/Account/Login" class="text-amber-300 underline font-bold">sign in</a> to rate or favorite this book
                        </p>
                    </div>
                }
            </div>

            <!-- Comments Section -->
            <div class="mt-12 border-t border-white/10 pt-8">
                <h2 class="text-2xl font-bold text-white mb-6">User Comments</h2>
                @if (ratings.Any())
                {
                    <div class="space-y-6">
                        @foreach (var rating in ratings)
                        {
                            <div class="bg-slate-800/30 rounded-2xl p-6 border border-white/5 backdrop-blur-sm">
                                <div class="flex justify-between items-start mb-4">
                                    <div class="flex items-center">
                                        <div class="w-10 h-10 rounded-full bg-indigo-500/20 flex items-center justify-center text-indigo-400 font-bold mr-3 border border-indigo-500/20">
                                            @(rating.User?.UserName?[0].ToString().ToUpper() ?? "?")
                                        </div>
                                        <div>
                                            <p class="text-white font-semibold">@rating.User?.UserName</p>
                                            <div class="flex text-amber-400">
                                                @for (int i = 1; i <= 5; i++)
                                                {
                                                    <svg class="w-3.5 h-3.5 @(i <= rating.Rating ? "fill-current" : "text-gray-600 fill-none stroke-current")" viewBox="0 0 24 24">
                                                        <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>
                                                    </svg>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                    @if(User.Identity.IsAuthenticated && rating.UserId == User.FindFirstValue(ClaimTypes.NameIdentifier))
                                    {
                                        <div class="flex space-x-2">
                                            <a asp-controller="BooksRating" asp-action="Edit" asp-route-id="@rating.Id" class="text-xs text-gray-400 hover:text-white transition-colors">Edit</a>
                                            <a asp-controller="BooksRating" asp-action="Delete" asp-route-id="@rating.Id" class="text-xs text-red-400/70 hover:text-red-400 transition-colors">Delete</a>
                                        </div>
                                    }
                                </div>
                                <p class="text-gray-300 leading-relaxed italic">"@rating.Text"</p>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-12 bg-slate-800/20 rounded-2xl border border-dashed border-white/10">
                        <p class="text-gray-500">No comments yet. Be the first to rate this book!</p>
                    </div>
                }
            </div>

            <!-- Navigation Links -->
            <div class="flex flex-wrap gap-4 pt-6 border-t border-white/10">
                <a asp-action="Edit" asp-route-id="@Model?.Id" 
                   class="px-5 py-2.5 bg-blue-500 hover:bg-blue-600 text-white font-medium rounded-lg transition-colors">
                    Edit Book
                </a>
                <a asp-action="Index" 
                   class="px-5 py-2.5 bg-slate-700 hover:bg-slate-600 text-white font-medium rounded-lg transition-colors flex items-center">
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
                    </svg>
                    Back to Library
                </a>
            </div>
        </div>
    </div>
</div>
