@model Bookss.Models.Book

@{
    ViewData["Title"] = "Delete";
}

<div class="flex items-center justify-center min-h-screen p-4 py-24">
    <div
        class="bg-slate-900/40 backdrop-blur-md border border-red-500/20 rounded-3xl shadow-2xl p-8 md:p-12 w-full max-w-xl mx-auto">
        <div class="text-center mb-10">
            <div
                class="w-20 h-20 bg-red-500/10 rounded-full flex items-center justify-center mx-auto mb-6 border border-red-500/20">
                <svg class="w-10 h-10 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z">
                    </path>
                </svg>
            </div>
            <h1 class="text-3xl font-bold text-white tracking-tight">Delete <span class="text-red-500">Book</span></h1>
            <p class="mt-2 text-gray-400 font-medium">Are you sure you want to remove <span
                    class="text-white font-bold">@Model.Title</span>?</p>
            <p class="mt-1 text-gray-500 text-sm italic">This action will permanently delete the book from the library.
            </p>
        </div>

        <div class="bg-slate-800/50 rounded-2xl p-6 border border-white/5 mb-8">
            <div class="flex items-center gap-6">
                <div
                    class="w-24 h-36 rounded-xl overflow-hidden bg-slate-800 border border-white/10 shrink-0 shadow-lg">
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img src="@Model.ImageUrl" alt="@Model.Title" class="w-full h-full object-cover" />
                    }
                    else
                    {
                        <div class="flex items-center justify-center h-full bg-linear-to-br from-slate-800 to-slate-900">
                            <span class="text-slate-600 text-3xl font-bold">@Model.Title[0]</span>
                        </div>
                    }
                </div>
                <div>
                    <h3 class="text-xl font-bold text-white mb-1">@Model.Title</h3>
                    <p class="text-sm text-indigo-400 mb-2">@Model.Genre?.Name</p>
                    <p class="text-xs text-gray-500 italic">by @Model.Author?.Name</p>
                </div>
            </div>
        </div>

        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />
            <div class="flex flex-col sm:flex-row gap-4">
                <button type="submit"
                    class="flex-1 px-8 py-4 bg-red-600 hover:bg-red-500 text-white font-bold rounded-2xl transition-all shadow-lg shadow-red-600/20 transform hover:-translate-y-1">
                    Confirm Delete
                </button>
                <a asp-action="Index"
                    class="px-8 py-4 bg-slate-700 hover:bg-slate-600 text-white font-bold rounded-2xl transition-all text-center no-underline!">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>
