@{
  ViewData["Title"] = "Home Page";
}
<div class="relative isolate px-6 pt-8 lg:px-8">
  <div class="mx-auto max-w-7xl py-12 sm:py-24 lg:py-32">
    <div class="text-center mb-16">
      <h1
        class="text-4xl font-bold tracking-tight sm:text-6xl bg-clip-text text-transparent bg-linear-to-r from-pink-400 via-purple-700 to-indigo-700">
        Welcome to our book store
      </h1>
      <p
        class="mt-6 font-bold tracking-tight  bg-clip-text text-transparent bg-linear-to-r from-pink-400 via-purple-700 to-indigo-700">
        Discover your next favorite story in our curated collection.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 items-start mb-24">
      <div
        class="relative group aspect-3/4 overflow-hidden rounded-2xl bg-gray-800 shadow-xl ring-1 ring-white/10 transform transition duration-300 hover:scale-[1.02]">
        <img src="/images/littlen.jpg" alt="Little Women"
          class="absolute inset-0 h-full w-full object-cover opacity-80 group-hover:opacity-100 transition-opacity duration-300" />
        <div class="absolute inset-x-0 bottom-0 bg-linear-to-t from-black/80 via-black/40 to-transparent p-6">
        </div>
      </div>

      <div
        class="relative group aspect-3/4 overflow-hidden rounded-2xl bg-gray-800 shadow-xl ring-1 ring-white/10 transform transition duration-300 hover:scale-[1.02] lg:mt-12">
        <img src="/images/book.jpg" alt="Featured Book"
          class="absolute inset-0 h-full w-full object-cover opacity-80 group-hover:opacity-100 transition-opacity duration-300" />
        <div class="absolute inset-x-0 bottom-0 bg-linear-to-t from-black/80 via-black/40 to-transparent p-6">
        </div>
      </div>

      <div
        class="relative group aspect-3/4 overflow-hidden rounded-2xl bg-gray-800 shadow-xl ring-1 ring-white/10 transform transition duration-300 hover:scale-[1.02]">
        <img src="/images/book1.jpg" alt="New Arrival"
          class="absolute inset-0 h-full w-full object-cover opacity-80 group-hover:opacity-100 transition-opacity duration-300" />
        <div class="absolute inset-x-0 bottom-0 bg-linear-to-t from-black/80 via-black/40 to-transparent p-6">
        </div>
      </div>
    </div>

    <!-- Quick Links Section -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <a asp-controller="Books" asp-action="Index" 
         class="group p-8 bg-slate-900/40 backdrop-blur-md border border-white/5 rounded-3xl hover:border-indigo-500/50 transition-all duration-500 hover:shadow-2xl hover:shadow-indigo-500/10 hover:-translate-y-2 no-underline!">
        <div class="w-12 h-12 bg-indigo-500/10 rounded-2xl flex items-center justify-center mb-6 border border-indigo-500/20 group-hover:scale-110 transition-transform">
          <svg class="w-6 h-6 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
          </svg>
        </div>
        <h3 class="text-2xl font-bold text-white mb-2 group-hover:text-indigo-400 transition-colors">Explore Books</h3>
        <p class="text-gray-400">Browse our extensive library of stories, knowledge, and high-quality titles.</p>
      </a>

      <a asp-controller="Genres" asp-action="Index" 
         class="group p-8 bg-slate-900/40 backdrop-blur-md border border-white/5 rounded-3xl hover:border-pink-500/50 transition-all duration-500 hover:shadow-2xl hover:shadow-pink-500/10 hover:-translate-y-2 no-underline!">
        <div class="w-12 h-12 bg-pink-500/10 rounded-2xl flex items-center justify-center mb-6 border border-pink-500/20 group-hover:scale-110 transition-transform">
          <svg class="w-6 h-6 text-pink-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path>
          </svg>
        </div>
        <h3 class="text-2xl font-bold text-white mb-2 group-hover:text-pink-400 transition-colors">By Genre</h3>
        <p class="text-gray-400">Discover books categorized by genre, from thrilling mysteries to heartwarming romances.</p>
      </a>

      <a asp-controller="Authors" asp-action="Index" 
         class="group p-8 bg-slate-900/40 backdrop-blur-md border border-white/5 rounded-3xl hover:border-cyan-500/50 transition-all duration-500 hover:shadow-2xl hover:shadow-cyan-500/10 hover:-translate-y-2 no-underline!">
        <div class="w-12 h-12 bg-cyan-500/10 rounded-2xl flex items-center justify-center mb-6 border border-cyan-500/20 group-hover:scale-110 transition-transform">
          <svg class="w-6 h-6 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
          </svg>
        </div>
        <h3 class="text-2xl font-bold text-white mb-2 group-hover:text-cyan-400 transition-colors">Our Authors</h3>
        <p class="text-gray-400">Meet the creative minds behind the books and explore their unique perspectives.</p>
      </a>
    </div>
  </div>
</div>